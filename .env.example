# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# Clerk authentication (get from clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Neon Postgres (get from console.neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic — used server-side only for the pricing monitor agent
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Firecrawl — used server-side only for competitor page scraping
FIRECRAWL_API_KEY=fc-your_key_here

# CareerOneStop — job search API (request access at careeronestop.org)
CAREER_ONESTOP_USER_ID=your_user_id_here
CAREER_ONESTOP_API_TOKEN=your_token_here

# Optional: set to "true" in .env.local only to bypass Clerk auth during Playwright tests
# PLAYWRIGHT_TESTING=true
